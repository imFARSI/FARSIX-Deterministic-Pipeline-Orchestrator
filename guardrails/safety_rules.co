# FARSIX Safety Rules — Colang 1.0
# NeMo Guardrails rule definitions for Semantic Output Validation.
# Evaluated using the NVIDIA NIM Cloud API via OpenAI adapter (meta/llama-3.1-8b-instruct).

# --- INTENT DEFINITIONS ---
# The LLM (8B) will read the output from the main Reasoning Agent (70B)
# and semantically classify if it falls into any of these dangerous intents.

define user said unsafe content
  "ignore previous instructions"
  "disregard rules"
  "override safety protocols"
  "jailbreak"
  "system prompt"

define user said hallucinated metrics
  "100% certainty"
  "I am absolutely certain with 0 probability of error"
  "I cannot report"
  "As an AI language model I don't have access"

define user said logical inconsistency
  "risk score is 0 but immediate action is required"
  "everything is safe but we must evacuate"
  "there are no anomalies but the system is failing"

# --- SEMANTIC GUARDRAIL FLOWS ---

define flow block unsafe content
  user said unsafe content
  bot safety violation detected

define flow block hallucination
  user said hallucinated metrics
  bot hallucination detected

define flow block inconsistency
  user said logical inconsistency
  bot logical inconsistency detected

# --- BOT RESPONSES ---

define bot output safe
  "GUARDRAILS_PASS: All semantic checks passed."

define bot refuse to respond
  "GUARDRAILS_BLOCK: Content failed safety check."

define bot safety violation detected
  "GUARDRAILS_BLOCK: Output contains safety violation."

define bot logical inconsistency detected
  "GUARDRAILS_BLOCK: Logical inconsistency detected."

define bot hallucination detected
  "GUARDRAILS_BLOCK: Potential hallucination detected."

define bot incomplete output detected
  "GUARDRAILS_BLOCK: Output is incomplete."
